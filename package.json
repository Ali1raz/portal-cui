{
  "name": "cui-portal",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "inngest:dev": "pnpm dlx inngest-cli@latest dev",
    "build": "next build && pnpm db:generate",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:sync": "pnpm db:push && pnpm db:generate",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio --browser none",
    "prepare": "husky",
    "postinstall": "pnpm db:generate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@arcjet/inspect": "^1.3.1",
    "@arcjet/ip": "^1.3.1",
