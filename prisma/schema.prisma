generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  role    Role     @default(USER)
  student Student?

  hod        Hod?
  professor  Professor?
  director   Director?
  accountant Accountant?

  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum Role {
  ACCOUNTANT
  DIRECTOR
  ADMIN
  HOD
  PROFESSOR
  STUDENT
  USER
}

enum Department {
  CS
  EN
  SE
  MATH
  BA
}

enum Batch {
  SP
  FA
}

enum Program {
  B
  M
}

model Student {
  id             String @id @default(uuid())
  registrationNo String @unique // FA22-BSE-001

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  program    Program
  department Department

  registration       Registration?
  enrollments        Enrollment[]
  studentAttendances StudentAttendance[]

  @@map("student")
}

model Hod {
  id         String     @id @default(uuid())
  department Department @unique // Each department can have only one HOD
  year       DateTime // date of appointment
  endYear    DateTime // End date of appointment

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([department])
  @@map("hod")
}

model Professor {
  id         String @id @default(uuid())
  employeeNo String @unique // EMP-001

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  department Department // Professors belong to a specific department
  programs   Program[] // Professors can be associated with a specific program or multiple programs

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  teachingAssignments TeachingAssignment[]

  @@index([department, employeeNo])
  @@map("professor")
}

model Director {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("director")
}

model Accountant {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("accountant")
}

model Subject {
  id          String @id @default(uuid())
  name        String
  code        String @unique // CS101
  creditHours Int    @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offerings SubjectOffering[]

  @@map("subject")
}

model SubjectOffering {
  id String @id @default(uuid())

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  semester      Int
  year          Int // 2024
  section       String
  totalLectures Int    @default(30)

  department Department

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments         Enrollment[]
  teachingAssignments TeachingAssignment[]
  attendanceRecords   AttendanceRecord[]

  @@unique([subjectId, semester, year])
  @@map("subject_offering")
}

model Enrollment {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  offeringId String
  offering   SubjectOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, offeringId])
  @@map("enrollment")
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

model Registration {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  semester Int
  year     Int

  status RegistrationStatus @default(PENDING)
  batch  Batch

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId])
  @@map("registration")
}

model TeachingAssignment {
  id String @id @default(uuid())

  professorId String
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)

  offeringId String
  offering   SubjectOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([professorId, offeringId]) // no professor can be assigned to the same section 
  @@unique([offeringId]) // Ensures a section can only have one professor
  @@map("teaching_assignment")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
}

model AttendanceRecord {
  id String @id @default(uuid())

  date      DateTime
  startTime DateTime
  endTime   DateTime
  topic     String

  offeringId String
  offering   SubjectOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendances StudentAttendance[]

  @@map("attendance_record")
}

model StudentAttendance {
  id String @id @default(uuid())

  status AttendanceStatus

  recordId String
  record   AttendanceRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recordId, studentId])
  @@map("student_attendance")
}
