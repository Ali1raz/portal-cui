    "motion": "^12.23.25",
    "next": "16.1.3",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.11",
    "nuqs": "^2.8.8",
    "pg": "^8.16.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.12.0",
