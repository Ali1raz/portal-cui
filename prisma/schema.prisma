generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  role    Role     @default(USER)
  student Student?

  hod          Hod?
  professor    Professor?
  director     Director?
  accountant   Accountant?
  batchAdvisor BatchAdvisor?
  clerk        Clerk?

  banned              Boolean?             @default(false)
  banReason           String?
  banExpires          DateTime?
  announcements       Announcement[]
  studentApplications StudentApplication[]

  registration Registration?

  username        String?
  displayUsername String?

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum Role {
  ACCOUNTANT
  DIRECTOR
  ADMIN
  HOD
  PROFESSOR
  STUDENT
  USER
  BATCH_ADVISOR
  CLERK
}

enum Department {
  CS
  EN
  SE
  MATH
  BA
}

enum Batch {
  SP
  FA
}

enum Program {
  B
  M
}

model Student {
  id             String @id @default(uuid())
  registrationNo String @unique // FA22-BSE-001

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  program    Program
  department Department

  registration             Registration[]
  enrollments              Enrollment[]
  studentAttendances       StudentAttendance[]
  leaveRequests            LeaveRequest[]
  complaints               Complaint[]
  studentFeeInstallments   StudentFeeInstallment[]
  installmentSplitRequests InstallmentSplitRequest[]
  studentSemesterFees      StudentSemesterFee[]
  feeVouchers              FeeVoucher[]

  @@map("student")
}

model Clerk {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clerk")
}

model Hod {
  id         String     @id @default(uuid())
  department Department @unique // Each department can have only one HOD

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([department])
  @@map("hod")
}

model BatchAdvisor {
  id         String     @id @default(uuid())
  department Department @unique // one BA per department, enforced at DB

  // A BA must already be a professor
  professorId String    @unique
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviewedComplaints ComplaintReview[] // BA's review log

  @@map("batch_advisor")
}

model Professor {
  id         String @id @default(uuid())
  employeeNo String @unique // EMP-001

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  department Department? // Professors belong to a specific department
  programs   Program[] // Professors can be associated with a specific program or multiple programs

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  teachingAssignments TeachingAssignment[]
  batchAdvisor        BatchAdvisor?

  @@index([department, employeeNo])
  @@map("professor")
}

model Director {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("director")
}

model Accountant {
  id           String        @id @default(uuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  semesterFees SemesterFee[]

  @@map("accountant")
}

model Subject {
  id          String @id @default(uuid())
  name        String
  code        String @unique // CS101
  creditHours Int    @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offerings SubjectOffering[]

  @@map("subject")
}

model SubjectOffering {
  id String @id @default(uuid())

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  semesterId String?
  semester   Semester? @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  totalLectures Int @default(30)

  department Department

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments         Enrollment[]
  teachingAssignments TeachingAssignment[]
  attendanceRecords   AttendanceRecord[]
  leaveRequests       LeaveRequest[]

  @@unique([subjectId, semesterId, department])
  @@map("subject_offering")
}

model Semester {
  id         String     @id @default(uuid())
  semester   Int
  year       Int
  department Department
  batch      Batch
  program    Program?   @default(B)

  registrationStart DateTime // when students can apply
  registrationEnd   DateTime
  enrollmentStart   DateTime // when subject selection opens (after BA approvals)
  enrollmentEnd     DateTime // subject selection deadline
  addDeadline       DateTime // last day to add a subject

  dropDeadline     DateTime // Drop the subject → completely removed, like you never enrolled. Nothing on your transcript
  lateDropDeadline DateTime // late drop deadline (W grade appears)
  isActive         Boolean  @default(false) // only one active window per dept+sem

  startDate DateTime
  endDate   DateTime

  registrations       Registration[]
  studentApplications StudentApplication[]
  subjectOfferings    SubjectOffering[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  semesterFees SemesterFee[]

  @@unique([semester, year, department, batch]) // ensures no duplicate semesters for same dept+batch
  @@map("semester")
}

model StudentApplication {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  semesterId String?
  semester   Semester? @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  fullName            String
  dateOfBirth         DateTime
  gender              Gender
  address             String
  city                String
  phoneNo             String
  // Previous academics
  previousDegree      String //— e.g. "Intermediate FSc Pre-Engineering"
  previousInstitution String
  previousPassingYear Int
  percentage          Decimal

  preferredDepartment Department

  // Status + clerk fields
  status      StudentApplicationStatus @default(PENDING)
  attemptNo   Int                      @default(1) // increments on each resubmit after rejection
  submittedAt DateTime? // when user finalized and submitted

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  applicationReviews ApplicationReview[]

  @@unique([userId, attemptNo])
  @@index([semesterId]) // for semester-wise application listing
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentApplicationStatus {
  PENDING
  REVIEW_REQUESTED
  APPROVED
  REJECTED
}

model ApplicationReview {
  id String @id @default(uuid())

  applicationId String
  application   StudentApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // Who acted
  actorRole ApplicationActorRole @default(USER) // USER | CLERK
  actorId   String // User.id of the actor

  // What happened
  action  ApplicationAction
  remarks String? // optional note left by actor

  // State transition (for timeline rendering)
  fromStatus StudentApplicationStatus? // optional when submitting
  toStatus   StudentApplicationStatus?

  createdAt DateTime @default(now())

  @@index([applicationId]) // fetch timeline for an application
  @@map("application_review")
}

enum ApplicationActorRole {
  USER
  CLERK
}

enum ApplicationAction {
  SUBMITTED // student submitted
  CLERK_APPROVED // CLERK approved, moves to next step in admission process
  CLERK_REJECTED // CLERK rejected — student can revise & resubmit → PENDING, or delete
  CLERK_REVIEW_REQUESTED // CLERK asked student to update details
  RESUBMITTED // student updated and resubmitted after CLERK review request
}

model Enrollment {
  id      String           @id @default(uuid())
  section String?          @default("A") // Default section is "A"
  status  EnrollmentStatus @default(PENDING)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  offeringId String
  offering   SubjectOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  registration   Registration? @relation(fields: [registrationId], references: [id])
  registrationId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, offeringId])
  @@index([registrationId]) // fetch all enrollments for a registration
  @@map("enrollment")
}

enum EnrollmentStatus {
  ENROLLED // student is currently enrolled and attending classes
  PENDING
  APPROVED
  REJECTED
  DROPPED // student dropped the subject before drop deadline, removed from enrollment and transcript
  WITHDRAWN // 
  COMPLETED
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  REVIEW_REQUESTED
  RESUBMITTED
  WITHDRAWN
}

model Registration {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status RegistrationStatus @default(PENDING)

  semesterId  String?
  semester    Semester?            @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  reviews     RegistrationReview[] // full audit trail of registration reviews
  enrollments Enrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, semesterId, userId])
  @@index([studentId, userId, semesterId])
  @@map("registration")
}

model RegistrationReview {
  id String @id @default(uuid())

  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  // Who acted
  actorRole RegistrationActorRole // STUDENT | CLERK
  actorId   String // User.id of the actor

  // What happened
  action  RegistrationAction
  remarks String? // optional note left by actor

  // State transition (for timeline rendering)
  fromStatus RegistrationStatus
  toStatus   RegistrationStatus

  createdAt DateTime @default(now())

  @@index([registrationId]) // fetch timeline for a registration
  @@map("registration_review")
}

enum RegistrationAction {
  SUBMITTED // student submitted
  CLERK_APPROVED // CLERK approved, can enroll subjects
  CLERK_REJECTED // CLERK rejected
  CLERK_REVIEW_REQUESTED // CLERK asked student to update details
  RESUBMITTED // student updated and resubmitted after CLERK review request
}

enum RegistrationActorRole {
  STUDENT
  CLERK
}

model TeachingAssignment {
  id String @id @default(uuid())

  professorId String
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)

  offeringId String
  offering   SubjectOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  section    String?         @default("A") // Default section is "A"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Ensures a section can only have one professor
  @@unique([professorId, offeringId, section]) // no professor can be assigned to the same section 
  @@map("teaching_assignment")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
}

enum LeaveStatus {
  PENDING
  REVIEW_REQUESTED
  HOD_PENDING
  APPROVED
  REJECTED
}

model AttendanceRecord {
  id String @id @default(uuid())

  date      DateTime
  startTime String
  endTime   String
  topic     String

  offeringId String
  offering   SubjectOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendances StudentAttendance[]

  @@map("attendance_record")
}

model StudentAttendance {
  id String @id @default(uuid())

  status AttendanceStatus

  recordId String
  record   AttendanceRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recordId, studentId])
  @@map("student_attendance")
}

model LeaveRequest {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  offeringId String
  offering   SubjectOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  date          DateTime
  reasonTitle   String
  reasonDetails String

  imageKey String?

  status  LeaveStatus          @default(PENDING)
  reviews LeaveRequestReview[] // full audit trail of reviews

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([offeringId])
  @@map("leave_request")
}

model LeaveRequestReview {
  id String @id @default(uuid())

  leaveRequestId String
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)

  // Who acted
  actorRole LRActorRole // STUDENT | BATCH_ADVISOR | HOD
  actorId   String // User.id of the actor

  // What happened
  action  LRAction
  remarks String? // optional note left by actor

  // State transition (for timeline rendering)
  fromStatus LeaveStatus
  toStatus   LeaveStatus

  createdAt DateTime @default(now())

  @@index([leaveRequestId]) // fetch timeline for a leave request
  @@map("leave_request_review")
}

enum LRActorRole {
  STUDENT
  BATCH_ADVISOR
  HOD
}

enum LRAction {
  SUBMITTED // student submitted
  BA_APPROVED // BA approved, forwarded to HOD
  BA_REJECTED // BA rejected
  BA_REVIEW_REQUESTED // BA asked student to update details
  RESUBMITTED // student updated and resubmitted after BA review request
  HOD_APPROVED // HOD approved leave
  HOD_REJECTED // HOD rejected leave
}

// Complaint model:

enum ComplaintCategory {
  ACADEMIC // grade disputes, course issues
  ADMINISTRATIVE // fee, registration, documents
  FACULTY // professor conduct
  FACILITY // labs, classrooms, equipment
  HARASSMENT
  OTHER
}

model Complaint {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  targetDepartment DepartmentToAssignComplaintTo?

  category ComplaintCategory // UC-9 Business Rule: must have valid category
  title    String
  details  String
  imageKey String?

  status ComplaintStatus @default(BA_PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments ComplaintAssignment[] // renamed from transfers — matches UC-10 language
  reviews     ComplaintReview[] // ← full audit trail

  @@index([studentId]) // UC-9: "only student's complaints shown"
  @@index([targetDepartment, status]) // 
  @@map("complaint")
}

enum ComplaintStatus {
  BA_PENDING // submitted by student, in BA queue
  BA_REVIEW_REQUESTED // BA ASK to UPDATE COMPLAINT DETAILS
  BA_REJECTED // BA rejected — student can revise & resubmit → BA_PENDING, or delete
  HOD_PENDING // BA accepted, now in HOD queue
  HOD_ACCEPTED // HOD resolved positively, terminal
  HOD_REJECTED // HOD resolved negatively, terminal
  ASSIGNED // HOD transferred to another dept (transient)
}

model ComplaintReview {
  id String @id @default(uuid())

  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  // Who acted
  actorRole ActorRole // STUDENT | BATCH_ADVISOR | HOD
  actorId   String // User.id of the actor

  // What happened
  action  ReviewAction
  remarks String? // optional note left by actor

  // State transition (for timeline rendering)
  fromStatus ComplaintStatus
  toStatus   ComplaintStatus

  // Department context (important for reassignment history)
  department Department

  createdAt DateTime @default(now())

  // FK to BatchAdvisor if actor is BA (for BA's own review history)
  batchAdvisorId String?
  batchAdvisor   BatchAdvisor? @relation(fields: [batchAdvisorId], references: [id])

  @@index([complaintId]) // fetch timeline for a complaint
  @@index([batchAdvisorId]) // BA's own review history
  @@map("complaint_review")
}

enum ActorRole {
  STUDENT
  BATCH_ADVISOR
  HOD
}

// Append-only log — covers UC-10 "HOD reassigns" alternative flow too
model ComplaintAssignment {
  id String @id @default(uuid())

  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  toDepartment DepartmentToAssignComplaintTo
  reason       String? // UC-10: reason for assignment / reassignment

  assignedAt DateTime @default(now())

  @@index([complaintId])
  @@map("complaint_assignment")
}

enum DepartmentToAssignComplaintTo {
  ACADEMIC_AFFAIRS // ACADEMIC complaints
  REGISTRAR // ADMINISTRATIVE complaints  
  FACILITIES // FACILITY complaints
  STUDENT_AFFAIRS // HARASSMENT complaints
  DEAN_OF_STUDENTS // OTHER / escalations
  // HOD is dynamic per faculty, handle as a relation not enum
}

// Immutable log of every action taken on a complaint
// Replaces guessing from status history — every actor's action is recorded

enum ReviewAction {
  SUBMITTED // student submitted
  BA_ACCEPTED // BA forwarded to HOD
  BA_REJECTED // BA rejected
  BA_REVIEW_REQUESTED // BA asked student to update details
  RESUBMITTED // student updated and resubmitted after BA review request
  HOD_ASSIGNED // HOD assigned to department
  HOD_ACCEPTED // HOD resolved positively
  HOD_REJECTED // HOD resolved negatively
}

enum AnnouncementStatus {
  DRAFT // saved but not visible to students
  SCHEDULED // will auto-publish at scheduledFor datetime cron-job handles transition to PUBLISHED
  PUBLISHED // live and visible
  ARCHIVED // soft-deleted / expired, hidden from students
}

enum AnnouncementType {
  ACADEMIC // HOD — exams, course changes, academic calendar
  FEE // Accountant — deadlines, dues, payments
  EVENT // Any actor — seminars, workshops
  GENERAL // Admin — policy, general info
  URGENT // Any actor — high-priority, pinned
}

model Announcement {
  id       String  @id @default(uuid())
  title    String
  content  String // rich text / markdown
  imageKey String? // optional banner image

  type   AnnouncementType
  status AnnouncementStatus @default(DRAFT)

  // ── Authorship ──────────────────────────────────────────
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  // ── Scheduling ──────────────────────────────────────────
  // null scheduledFor = publish immediately on status → PUBLISHED
  scheduledFor DateTime? // future datetime for auto-publish
  publishedAt  DateTime? // set by system when status flips to PUBLISHED

  // ── Audience Targeting ──────────────────────────────────
  // All null = broadcast to ALL students (Admin use case)
  // HOD will always set targetDepartment = their own department
  // Accountant may target all or a specific program/batch
  targetDepartment Department? // null = all departments
  targetProgram    Program? // null = all programs (B + M)
  targetBatch      Batch? // null = all batches (SP + FA)
  targetYear       Int? // null = all years e.g. 2022

  // ── Engagement ──────────────────────────────────────────
  isPinned Boolean @default(false) // surfaced at top for URGENT

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt]) // for student feed query
  @@index([authorId]) // for author's own listing
  @@index([targetDepartment]) // for HOD-scoped queries
  @@index([status, isPinned, publishedAt]) // for pinned-first ordering
  @@map("announcement")
}

// ----------------
// FEE INSTALLMENTS

// 1. accountant creates
model SemesterFee {
  id String @id @default(uuid())

  accountantId String
  accountant   Accountant @relation(fields: [accountantId], references: [id])

  semesterId  String            @unique
  semester    Semester          @relation(fields: [semesterId], references: [id])
  totalAmount Decimal           @db.Decimal(10, 2)
  description String?
  status      SemesterFeeStatus @default(DRAFT)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  feeInstallments     FeeInstallment[]
  studentSemesterFees StudentSemesterFee[]

  @@index([semesterId, status])
  @@map("semester_fee")
}

enum SemesterFeeStatus {
  DRAFT
  PUBLISHED
}

enum FinePolicyType {
  FIXED // flat charge applied once past due date
  PER_DAY // dailyRate × daysOverdue
}

model FeeInstallment {
  id            String      @id @default(uuid())
  semesterFeeId String
  semesterFee   SemesterFee @relation(fields: [semesterFeeId], references: [id], onDelete: Cascade)
  installmentNo Int // 1 or 2 (auto generated in action)
  amount        Decimal     @db.Decimal(10, 2)
  dueDate       DateTime
  description   String?

  // Fine policy configuration (applied at read time)
  fineType      FinePolicyType? // null = no fine
  fineAmount    Decimal?        @db.Decimal(10, 2) // flat amount or per-day rate
  fineMaxDays   Int? // PER_DAY only — stop charging after N days
  fineCapAmount Decimal?        @db.Decimal(10, 2) // PER_DAY only — max total fine in PKR

  studentFeeInstallments StudentFeeInstallment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([semesterFeeId, installmentNo])
  @@map("fee_installment")
}

// =============================
// 2. student specific 

model StudentSemesterFee {
  id            String      @id @default(uuid())
  studentId     String
  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  semesterFeeId String
  semesterFee   SemesterFee @relation(fields: [semesterFeeId], references: [id], onDelete: Cascade)

  totalDue Decimal                  @db.Decimal(10, 2) // Can be adjusted (scholarship, etc.)
  status   StudentSemesterFeeStatus @default(PENDING)

  installments  StudentFeeInstallment[]
  splitRequests InstallmentSplitRequest[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  @@unique([studentId, semesterFeeId])
  @@index([studentId, status])
  @@map("student_semester_fees")
}

enum StudentSemesterFeeStatus {
  PENDING
  PAID
}

enum FineStatus {
  PENDING
  APPLIED
  WAIVED
  PAID
}

// created when hod accepted InstallmentSplitRequest
// which is created by student
model StudentFeeInstallment {
  id        String  @id @default(uuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  amount  Decimal                     @db.Decimal(10, 2) // may differ from base if split approved
  status  StudentFeeInstallmentStatus @default(UNPAID)
  isBase  Boolean                     @default(true) // false = created by split approval
  orderNo Int // 1, 2, or 3 — needed for display ordering

  paidAt  DateTime?
  dueDate DateTime

  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  installmentSplitRequests InstallmentSplitRequest[]

  feeInstallment   FeeInstallment? @relation(fields: [feeInstallmentId], references: [id], onDelete: Cascade)
  feeInstallmentId String? // null for split-generated chunks

  studentSemesterFee   StudentSemesterFee? @relation(fields: [studentSemesterFeeId], references: [id], onDelete: Cascade)
  studentSemesterFeeId String?
  feeVouchers          FeeVoucher[]

  @@unique([studentSemesterFeeId, orderNo])
  @@index([studentId]) // student's fee page
  @@index([studentId, status])
  @@map("student_fee_installment")
}

enum StudentFeeInstallmentStatus {
  UNPAID
  PAID
  // OVERDUE use dueDate < now() && status == UNPAID → treat as overdue in query layer
}

model InstallmentSplitRequest {
  id String @id @default(uuid())

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  requestedAmount  Decimal  @db.Decimal(10, 2)
  reason           String
  preferredDueDate DateTime // student's proposed due date for the split chunk

  status SplitRequestStatus @default(PENDING)

  reviews InstallmentSplitRequestReview[]

  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  studentFeeInstallment   StudentFeeInstallment? @relation(fields: [studentFeeInstallmentId], references: [id])
  studentFeeInstallmentId String?
  studentSemesterFee      StudentSemesterFee?    @relation(fields: [studentSemesterFeeId], references: [id])
  studentSemesterFeeId    String?

  @@index([status])
  @@map("installment_split_request")
}

model InstallmentSplitRequestReview {
  id String @id @default(uuid())

  splitRequestId String
  splitRequest   InstallmentSplitRequest @relation(fields: [splitRequestId], references: [id], onDelete: Cascade)

  // Who acted
  actorRole InstallmentSplitReviewActorRole // STUDENT | HOD | ACCOUNTANT
  actorId   String // User.id of the actor

  // What happened
  action  InstallmentSplitReviewAction
  remarks String? // optional note left by actor

  // State transition (for timeline rendering)
  fromStatus SplitRequestStatus
  toStatus   SplitRequestStatus

  createdAt DateTime @default(now())

  @@index([splitRequestId]) // fetch timeline for a split request
  @@map("installment_split_request_review")
}

enum InstallmentSplitReviewActorRole {
  STUDENT
  HOD
  ACCOUNTANT
}

enum InstallmentSplitReviewAction {
  SUBMITTED
  RESUBMITTED
  HOD_REVIEW_REQUESTED
  HOD_APPROVED
  HOD_REJECTED
  APPROVED
  REJECTED
  CANCELLED // actor = student
}

enum SplitRequestStatus {
  PENDING
  CANCELLED
  HOD_REVIEW_REQUESTED
  HOD_APPROVED
  HOD_REJECTED
  APPROVED
  REJECTED
}

// ---------
// voucher

enum VoucherStatus {
  ACTIVE // generated, not yet used or expired
  USED // payment confirmed
  EXPIRED // past expiryDate and status was still ACTIVE
}

model FeeVoucher {
  id String @id @default(uuid())

  voucherNo String @unique // e.g. "2024000042" — formatted serial

  studentFeeInstallmentId String
  studentFeeInstallment   StudentFeeInstallment @relation(fields: [studentFeeInstallmentId], references: [id], onDelete: Cascade)
  studentId               String
  student                 Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)

  amount     Decimal  @db.Decimal(10, 2)
  dueDate    DateTime // copied from StudentFeeInstallment.dueDate at voucher generation time
  expiryDate DateTime // end of generation day (23:59:59) — voucher valid today only

  status    VoucherStatus @default(ACTIVE)
  usedAt    DateTime? // set when status → USED
  expiredAt DateTime? // set when status → EXPIRED (by cron/inngest)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentFeeInstallmentId, status, expiryDate]) // idempotency check
  @@index([status, expiryDate]) // expiry sweep query
  @@index([studentId, status]) // per-student voucher listing
  @@index([voucherNo]) // lookup by voucher number at payment desk
  @@map("fee_voucher")
}

model FeeVoucherCounter {
  id  Int    @id @default(1) // single-row table
  seq BigInt @default(0)

  @@map("fee_voucher_counter")
}
